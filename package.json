{
  "name": "michaelajanceova",
  "version": "1.0.0",
  "description": "MongoDB Express Node TypeScript REST API",
  "license": "ISC",
  "author": "michaelajanceova",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "build": "rm -rf ./dist && tsc",
    "start-dev": "npx nodemon",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "nodemonConfig": {
    "verbose": false,
    "watch": [
      "src"
    ],
    "ext": "js,ts",
    "exec": "npx ts-node ./src/index.ts",
    "ignore": [
      "node_modules"
    ]
  },
  "dependencies": {
    "@types/joi": "^17.2.2",
    "@types/node": "^25.1.0",
    "cross-env": "^10.1.0",
    "dotenv-flow": "^4.1.0",
    "express": "^5.2.1",
    "joi": "^18.0.2",
    "mongodb": "^7.0.0",
    "mongoose": "^9.1.5",
    "nodemon": "^3.1.11"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
