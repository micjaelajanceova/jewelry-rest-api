{
  "name": "michaelajanceova",
  "version": "1.0.0",
  "description": "MongoDB Express Node TypeScript REST API",
  "license": "ISC",
  "author": "michaelajanceova",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "build": "rm -rf ./dist && tsc",
    "start": "node dist/index.js",
    "start-dev": "cross-env NODE_ENV=development npx nodemon",
    "seed": "npx ts-node ./src/util/dataSeeder.ts",
    "lint": "npx eslint",
    "testdb": "cross-env NODE_ENV=test npx ts-node ./src/index.ts",
    "test": "npx playwright test --reporter=html"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/micjaelajanceova/jewelry-rest-api"
  },
  "bugs": {
    "url": "https://github.com/micjaelajanceova/jewelry-rest-api/issues"
  },
  "homepage": "https://github.com/micjaelajanceova/jewelry-rest-api#readme",
  "nodemonConfig": {
    "verbose": false,
    "watch": [
      "src"
    ],
    "ext": "js,ts",
    "exec": "npx ts-node ./src/index.ts",
    "ignore": [
      "node_modules"
    ]
  },
  "dependencies": {
    "@faker-js/faker": "^10.3.0",
    "@types/joi": "^17.2.2",
    "@types/node": "^25.1.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "dotenv-flow": "^4.1.0",
    "express": "^5.2.1",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.0.0",
    "mongoose": "^9.1.5",
    "node-cron": "^4.2.1",
    "nodemon": "^3.1.11",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "eslint": "^10.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  }
}
